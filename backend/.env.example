# Postgres (Neon / Supabase / 로컬)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hacker

# Copilot session memory (development/demo default: persistent Postgres)
COPILOT_SESSION_STORE=postgres
COPILOT_SESSION_STORE_URL=postgresql://postgres:postgres@localhost:5432/hacker
COPILOT_SESSION_MAX_TURNS=50
COPILOT_SESSION_TTL_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Naver Search API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Embedding provider: fake (기본, 심사 재현성) | openai | voyage
COPILOT_EMBED_PROVIDER=fake

# FastAPI
DEBUG=false
